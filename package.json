{
  "name": "usersconnect",
  "version": "1.1.0",
  "description": "Server-Side Rendered Node.js/TypeScript website developed during a backend development internship",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "clean": "shx rm -rf dist",
    "build": "npm run clean && tsc && npm run copy:views && npm run copy:public",
    "copy:views": "copyfiles -u 1 \"src/views/**/*.hbs\" dist",
    "copy:public": "copyfiles -u 1 \"src/public/**/*\" dist",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/dataSource.ts",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run -d src/config/dataSource.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/dataSource.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/dataSource.ts"
  },
  "author": "Omair Salman",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "express-handlebars": "^6.0.7",
    "express-validator": "^7.2.1",
    "handlebars": "^4.7.9",
    "ioredis": "^5.7.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.14.3",
    "nodemailer": "^8.0.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.1.0",
    "@types/nodemailer": "^7.0.9",
    "copyfiles": "^2.4.1",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "shx": "^0.4.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "typeorm": "^0.3.28"
  }
}
