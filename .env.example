# ============================================
# UsersConnect — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#
# PRIORITY: Environment variables override config.yaml settings.
# ALTERNATIVE: You can configure most settings in config.yaml instead.
#              See config.example.yaml for the full YAML reference.
#
# NOTE: Internal port is hardcoded to 3000 (matches Dockerfile EXPOSE 3000).
#       Use Docker port mapping for external exposure: docker run -p 8080:3000

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production

# ============================================
# DATABASE (Required)
# ============================================
DATABASE_HOST=mysql
DATABASE_USERNAME=root
DATABASE_PASSWORD=your_secure_password
DATABASE_NAME=usersconnect

# ============================================
# REDIS (Required)
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=your_redis_password

# ============================================
# JWT SECRETS (Required)
# ============================================
# Generate secure random strings for production:
#   openssl rand -base64 32
ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# ============================================
# GRAVATAR (Optional)
# ============================================
# GRAVATAR_API_KEY=your_gravatar_api_key

# ============================================
# S3 STORAGE (Optional)
# ============================================
# Required for custom profile pictures and post images.
# Leave commented out to disable image uploads.
# For non-AWS providers (MinIO, Cloudflare R2, DigitalOcean Spaces), set S3_ENDPOINT.
# S3_ACCESS_KEY=your_s3_access_key
# S3_SECRET_KEY=your_s3_secret_key
# S3_BUCKET_NAME=usersconnect-media
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_PUBLIC_URL=https://cdn.example.com

# ============================================
# SMTP EMAIL (Optional)
# ============================================
# Required for email verification, password reset, and email changes.
# Leave commented out to disable email features.
# When disabled, users can register and use the platform immediately without verification.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM_NAME=UsersConnect
# SMTP_FROM_EMAIL=noreply@example.com

# ============================================
# CORS (Optional)
# ============================================
# Enable only when a separate frontend (Angular, React, Vue, etc.) accesses the API.
# Leave disabled for server-side rendering (SSR) only deployments.
# CORS_ENABLED=false
# CORS_ALLOWED_ORIGINS=http://localhost:4200,https://app.example.com
# CORS_ALLOW_CREDENTIALS=true
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept

# ============================================
# LOGGING (Optional)
# ============================================
# LOG_LEVEL=info
# Options: error | warn | info | debug